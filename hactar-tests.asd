	       (:file "tests/mcp.test")
	       (:file "tests/rules.test")
	       (:file "tests/skills.test")
	       (:file "tests/state.test")
	       (:file "tests/starters.test")
	       (:file "tests/interface.test")
	       (:file "tests/hydra.test")
