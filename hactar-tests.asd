(asdf:defsystem #:hactar-tests
  :description "Test suite for Hactar"
  :author "K-2052"
  :license "MIT"
  :depends-on (#:hactar #:fiveam #:hactar-migrations #:mockingbird #:str)
  :components ((:file "tests/package")
               (:file "tests/suite")
               (:file "tests/core.test")
               (:file "tests/errors.test")
               (:file "tests/org-parser.test")
               (:file "tests/org-utils.test")
	       (:file "tests/markdown.test")
               (:file "tests/router.test")
               (:file "tests/web-command.test")
               (:file "tests/ai-comment.test")
               (:file "tests/import.test")
               (:file "tests/npm.test")
               (:file "tests/agent.test")
               (:file "tests/coverage-gap.test")
               (:file "tests/coverage.test")
	       (:file "tests/context.test")
               (:file "tests/agent.typecheck.test")
               (:file "tests/agent.testagent.test")
               (:file "tests/utils.test")
               (:file "tests/copilot.test")
               (:file "tests/code-values.test")
               (:file "tests/ctags.test")
               (:file "tests/preset.test")
               (:file "tests/session.test")
	       (:file "tests/processors.test")
               (:file "tests/lisp-mode.test")
               (:file "tests/ruhe.test")
               (:file "tests/stripe.test")
               (:file "tests/guide.test")
               (:file "tests/generator.test")
               (:file "tests/bot.test")
	       (:file "tests/feature.test")
               (:file "tests/hyperfractal.test")
               (:file "tests/tools.test")
	       (:file "tests/lisp-rpc.test")
	       (:file "tests/permissions.test")
	       (:file "tests/mold.test")
               (:file "tests/tui.test")
	       (:file "tests/acp.test")
	       (:file "tests/mcp.test")
	       (:file "tests/rules.test")
	       (:file "tests/skills.test")
	       (:file "tests/state.test")
	       (:file "tests/to-org.test")
               (:file "tests/monolith.test")
	       (:file "tests/litmode.test")
               (:file "hactar-tests"))
  :perform (asdf:test-op (op c) (uiop:symbol-call :hactar-tests '#:run-tests)))
