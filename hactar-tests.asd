               (:file "tests/ctags.test")
               (:file "tests/preset.test")
               (:file "tests/session.test")
	       (:file "tests/processors.test")
               (:file "tests/lisp-mode.test")
               (:file "tests/ruhe.test")
               (:file "tests/stripe.test")
               (:file "tests/guide.test")
	       (:file "tests/hyperfractal.test")
